task freeviewing
 table visione
 show bitmap fixpoint6
 delay 500
 clear -1
 delay 500
 show bitmap @1   
 delay 1000          
 clear -1         
 delay 200     
 save TASKNAME BLOCKNAME @1 @2


block freeviewing 
 message istrmem1 space  
 tasklist         
   freeviewing 21 all_before_reapeat
 end




