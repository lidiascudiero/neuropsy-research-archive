l: stileattaccamento
t: set
- if $ansiascore >= 29.5  and  $evitamentoscore >= 15.5 then "disorganizzato"
- if $ansiascore >= 29.5  and  $evitamentoscore <= 15.5 then "ansioso"
- if $ansiascore < 29.5  and  $evitamentoscore < 15.5 then "sicuro"
- if $ansiascore < 29.5  and  $evitamentoscore >= 15.5 then "evitante"

