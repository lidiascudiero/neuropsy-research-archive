task riconoscimento
 keys x m 
 show bitmap fixpoint6
 delay 500
 clear -1
 delay 500
 table vecchionuovo
 show bitmap vecchio1 -250 250
 show bitmap nuovo1  250 250
 show bitmap @1 
 readkey @2 4000  
 delay 1000          
 clear -1         
 delay 200     
 save TASKNAME BLOCKNAME @1 KEY RT STATUS @3 @4 @5




block riconoscimento 
 message istrmem2 space 
 tasklist
  riconoscimento 42 all_before_reapeat  
 end
